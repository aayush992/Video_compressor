# Copy this file to .env.local and fill in real values before running locally.
# In Vercel, add these as Environment Variables in the dashboard.

# Backend URL — local dev
VITE_API_BASE=http://localhost:8001

# Production: replace with your Render URL
# VITE_API_BASE=https://media-compressor-api.onrender.com

# Google OAuth Client ID (same value used in backend .env → GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
