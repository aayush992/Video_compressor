# Copy this file to .env and fill in real values.
# Never commit the .env file — it is in .gitignore.

# ── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ── JWT Secret ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-a-random-64-char-string

# ── Database ─────────────────────────────────────────────────────────────────
# Leave blank to use SQLite (dev.db) locally
# DATABASE_URL=postgresql://user:password@host:5432/media_compressor

# ── Cloudinary (optional — local disk used if blank) ────────────────────────
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list. Add your Vercel URL in production.
ALLOWED_ORIGIN=http://localhost:5173
